{
  "name": "@calendar/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "start": "node dist/index.js",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:d1:create": "wrangler d1 create calendar-db --location apac --update-config",
    "cf:d1:migrate": "wrangler d1 migrations apply calendar-db --remote"
  },
  "dependencies": {
    "@calendar/plugin-fdzc-course": "workspace:*",
    "@cloudflare/workers-types": "^4.20260531.1",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.0.0",
    "scrypt-js": "^3.0.1",
    "tsx": "^4.0.0",
    "wrangler": "^4.95.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/scrypt-js": "^3.0.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.5.0",
    "wrangler": "^4.95.0"
  }
}
